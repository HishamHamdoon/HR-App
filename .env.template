# Copy this file to ".env" and set strong, unique values BEFORE running docker compose.
#   cp .env.template .env
# Never commit the real .env to source control.

# SQL Server 'sa' password (8+ chars, upper/lower/digit/symbol).
DB_PASSWORD=Change_This_Strong_Pass123!

# JWT signing secret for the API (use 32+ random characters).
JWT_SECRET=change-this-to-a-32-plus-character-random-secret

# License signing secret. MUST match the secret you use with the licensegen tool
# to mint this client's key. Keep it private.
LICENSING_SECRET=change-this-licensing-secret-keep-it-private

# Port on the host where staff open the app in their browser (http://<server>:<WEB_PORT>).
WEB_PORT=8080

# The browser-facing origin of the Web app (used for API CORS).
WEB_ORIGIN=http://localhost:8080

# Leave as Production for client installs (disables dev-only seeding & key generation).
ASPNETCORE_ENVIRONMENT=Production
