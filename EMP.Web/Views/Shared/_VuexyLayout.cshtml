@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isAdmin = User.IsInRole("Admin");
    var userName = User.Identity?.Name ?? "User";
    var userRole = isAdmin ? "Admin" : "Employee";

    string Active(string ctrl, string action = null) =>
        (controller == ctrl && (action == null || currentAction == action)) ? "active" : "";
}
<!doctype html>
<html lang="en"
      class="layout-navbar-fixed layout-menu-fixed layout-compact"
      dir="ltr"
      data-skin="default"
      data-assets-path="/vuexy/assets/"
      data-template="vertical-menu-template"
      data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
    <title>@ViewData["Title"] - HR Admin</title>

    <link rel="icon" type="image/x-icon" href="/vuexy/assets/img/favicon/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="/vuexy/assets/vendor/fonts/iconify-icons.css" />
    <link rel="stylesheet" href="/vuexy/assets/vendor/libs/node-waves/node-waves.css" />
    <link rel="stylesheet" href="/vuexy/assets/vendor/css/core.css" />
    <link rel="stylesheet" href="/vuexy/assets/css/demo.css" />
    <link rel="stylesheet" href="/vuexy/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.css" />
    <link rel="stylesheet" href="/vuexy/assets/vendor/libs/select2/select2.css" />
    <link rel="stylesheet" href="/vuexy/assets/vendor/libs/flatpickr/flatpickr.css" />

    <link rel="stylesheet" href="~/toastr.js/toastr.min.css" />
    @await RenderSectionAsync("Styles", required: false)

    <script src="/vuexy/assets/vendor/js/helpers.js"></script>
    <script src="/vuexy/assets/js/config.js"></script>
</head>

<body>
    <div class="layout-wrapper layout-content-navbar">
        <div class="layout-container">
            <!-- Menu -->
            <aside id="layout-menu" class="layout-menu menu-vertical menu">
                <div class="app-brand demo">
                    <a asp-controller="Home" asp-action="Index" class="app-brand-link">
                        <span class="app-brand-logo demo text-primary">
                            <i class="icon-base ti tabler-building-skyscraper" style="font-size:1.75rem;"></i>
                        </span>
                        <span class="app-brand-text demo menu-text fw-bold ms-3">HR Admin</span>
                    </a>
                    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
                        <i class="icon-base ti menu-toggle-icon d-none d-xl-block"></i>
                        <i class="icon-base ti tabler-x d-block d-xl-none"></i>
                    </a>
                </div>

                <div class="menu-inner-shadow"></div>

                <ul class="menu-inner py-1">
                    @if (isAdmin)
                    {
                        <li class="menu-item @Active("Home")">
                            <a asp-controller="Home" asp-action="Index" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-smart-home"></i>
                                <div>Dashboard</div>
                            </a>
                        </li>
                        <li class="menu-header small"><span class="menu-header-text">Management</span></li>
                        <li class="menu-item @Active("Employees")">
                            <a asp-controller="Employees" asp-action="Index" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-users"></i>
                                <div>Employees</div>
                            </a>
                        </li>
                        <li class="menu-item @Active("Leaves")">
                            <a asp-controller="Leaves" asp-action="Index" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-calendar"></i>
                                <div>Leaves</div>
                            </a>
                        </li>
                        <li class="menu-item @Active("LeavesType")">
                            <a asp-controller="LeavesType" asp-action="Index" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-list-details"></i>
                                <div>Leave Types</div>
                            </a>
                        </li>
                        <li class="menu-item @Active("Departments")">
                            <a asp-controller="Departments" asp-action="Index" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-building"></i>
                                <div>Departments</div>
                            </a>
                        </li>
                        <li class="menu-item @Active("JobTitles")">
                            <a asp-controller="JobTitles" asp-action="Index" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-briefcase"></i>
                                <div>Job Titles</div>
                            </a>
                        </li>
                        <li class="menu-item @Active("Countries")">
                            <a asp-controller="Countries" asp-action="Index" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-world"></i>
                                <div>Countries</div>
                            </a>
                        </li>
                        <li class="menu-item @Active("Salaries")">
                            <a asp-controller="Salaries" asp-action="Index" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-currency-dollar"></i>
                                <div>Salaries</div>
                            </a>
                        </li>
                        <li class="menu-header small"><span class="menu-header-text">System</span></li>
                        <li class="menu-item @Active("Reports")">
                            <a asp-controller="Reports" asp-action="Index" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-chart-line"></i>
                                <div>HR Reports</div>
                            </a>
                        </li>
                        <li class="menu-item @Active("Roles")">
                            <a asp-controller="Roles" asp-action="Index" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-shield-lock"></i>
                                <div>Roles &amp; Permissions</div>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="menu-item @Active("Home", "EmployeeDashboard")">
                            <a asp-controller="Home" asp-action="EmployeeDashboard" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-smart-home"></i>
                                <div>Dashboard</div>
                            </a>
                        </li>
                        <li class="menu-item @Active("Leaves", "Create")">
                            <a asp-controller="Leaves" asp-action="Create" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-calendar-plus"></i>
                                <div>Apply Leave</div>
                            </a>
                        </li>
                        <li class="menu-item @Active("Leaves", "EmployeeLeaves")">
                            <a asp-controller="Leaves" asp-action="EmployeeLeaves" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-calendar"></i>
                                <div>My Leaves</div>
                            </a>
                        </li>
                        <li class="menu-item @Active("Account", "Profile")">
                            <a asp-controller="Account" asp-action="Profile" class="menu-link">
                                <i class="menu-icon icon-base ti tabler-user"></i>
                                <div>My Profile</div>
                            </a>
                        </li>
                    }
                </ul>
            </aside>
            <!-- / Menu -->

            <div class="layout-page">
                <!-- Navbar -->
                <nav class="layout-navbar container-xxl navbar-detached navbar navbar-expand-xl align-items-center bg-navbar-theme" id="layout-navbar">
                    <div class="layout-menu-toggle navbar-nav align-items-xl-center me-3 me-xl-0 d-xl-none">
                        <a class="nav-item nav-link px-0 me-xl-6" href="javascript:void(0)">
                            <i class="icon-base ti tabler-menu-2 icon-md"></i>
                        </a>
                    </div>

                    <div class="navbar-nav-right d-flex align-items-center justify-content-end" id="navbar-collapse">
                        <ul class="navbar-nav flex-row align-items-center ms-md-auto">
                            <li class="nav-item navbar-dropdown dropdown-user dropdown">
                                <a class="nav-link dropdown-toggle hide-arrow p-0" href="javascript:void(0);" data-bs-toggle="dropdown">
                                    <div class="avatar avatar-online">
                                        <span class="avatar-initial rounded-circle bg-label-primary">@(userName.Length > 0 ? userName.Substring(0,1).ToUpper() : "U")</span>
                                    </div>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="javascript:void(0)">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-shrink-0 me-3">
                                                    <div class="avatar avatar-online">
                                                        <span class="avatar-initial rounded-circle bg-label-primary">@(userName.Length > 0 ? userName.Substring(0,1).ToUpper() : "U")</span>
                                                    </div>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <h6 class="mb-0">@userName</h6>
                                                    <small class="text-body-secondary">@userRole</small>
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                    <li><div class="dropdown-divider my-1 mx-n2"></div></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="icon-base ti tabler-user icon-md me-3"></i><span>My Profile</span>
                                        </a>
                                    </li>
                                    <li><div class="dropdown-divider my-1 mx-n2"></div></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">
                                                <i class="icon-base ti tabler-power icon-md me-3"></i><span>Log Out</span>
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </nav>
                <!-- / Navbar -->

                <div class="content-wrapper">
                    <div class="container-xxl flex-grow-1 container-p-y">
                        @RenderBody()
                    </div>

                    <footer class="content-footer footer bg-footer-theme">
                        <div class="container-xxl">
                            <div class="footer-container d-flex align-items-center justify-content-between py-4 flex-md-row flex-column">
                                <div class="text-body">© @DateTime.Now.Year HR Management System</div>
                            </div>
                        </div>
                    </footer>

                    <div class="content-backdrop fade"></div>
                </div>
            </div>
        </div>

        <div class="layout-overlay layout-menu-toggle"></div>
        <div class="drag-target"></div>
    </div>

    <script src="/vuexy/assets/vendor/libs/jquery/jquery.js"></script>
    <script src="/vuexy/assets/vendor/libs/popper/popper.js"></script>
    <script src="/vuexy/assets/vendor/js/bootstrap.js"></script>
    <script src="/vuexy/assets/vendor/libs/node-waves/node-waves.js"></script>
    <script src="/vuexy/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.js"></script>
    <script src="/vuexy/assets/vendor/libs/hammer/hammer.js"></script>
    <script src="/vuexy/assets/vendor/js/menu.js"></script>
    <script src="/vuexy/assets/vendor/libs/select2/select2.js"></script>
    <script src="/vuexy/assets/vendor/libs/flatpickr/flatpickr.js"></script>
    <script src="/vuexy/assets/js/main.js"></script>

    <script src="~/toastr.js/toastr.min.js"></script>

    <script>
        // Upgrade dropdowns to searchable Select2 and date inputs to Flatpickr.
        document.addEventListener('DOMContentLoaded', function () {
            if (window.jQuery && jQuery.fn.select2) {
                jQuery('select.form-select:not([data-no-select2])').each(function () {
                    var $el = jQuery(this);
                    var $modal = $el.closest('.modal');
                    var ph = $el.find('option[value=""]').first().text() || 'Select...';
                    $el.select2({
                        placeholder: ph,
                        width: '100%',
                        dropdownParent: $modal.length ? $modal : undefined
                    });
                });
            }

            if (typeof flatpickr !== 'undefined') {
                flatpickr('input[type="date"]', { dateFormat: 'Y-m-d', allowInput: true, disableMobile: true });
            }

            // Lightweight client-side pagination for any <table data-paginate="N">.
            document.querySelectorAll('table[data-paginate]').forEach(function (table) {
                var pageSize = parseInt(table.getAttribute('data-paginate'), 10) || 10;
                var tbody = table.querySelector('tbody');
                if (!tbody) return;
                var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
                if (rows.length <= pageSize) return;

                var pageCount = Math.ceil(rows.length / pageSize);
                var current = 1;

                var footer = document.createElement('div');
                footer.className = 'card-footer d-flex align-items-center justify-content-between flex-wrap gap-2';
                var info = document.createElement('span');
                info.className = 'text-body-secondary';
                var nav = document.createElement('nav');
                var ul = document.createElement('ul');
                ul.className = 'pagination mb-0';
                nav.appendChild(ul);
                footer.appendChild(info);
                footer.appendChild(nav);
                (table.closest('.card') || table.parentNode).appendChild(footer);

                function render() {
                    rows.forEach(function (r, i) {
                        r.style.display = (Math.floor(i / pageSize) + 1 === current) ? '' : 'none';
                    });
                    var from = (current - 1) * pageSize + 1;
                    var to = Math.min(current * pageSize, rows.length);
                    info.textContent = 'Showing ' + from + '–' + to + ' of ' + rows.length;
                    ul.innerHTML = '';
                    function btn(label, page, disabled, active) {
                        var li = document.createElement('li');
                        li.className = 'page-item' + (disabled ? ' disabled' : '') + (active ? ' active' : '');
                        var a = document.createElement('a');
                        a.className = 'page-link';
                        a.href = 'javascript:void(0)';
                        a.innerHTML = label;
                        a.addEventListener('click', function () {
                            if (!disabled && page !== current) { current = page; render(); }
                        });
                        li.appendChild(a);
                        ul.appendChild(li);
                    }
                    btn('<i class="icon-base ti tabler-chevron-left"></i>', current - 1, current === 1, false);
                    for (var p = 1; p <= pageCount; p++) btn(p, p, false, p === current);
                    btn('<i class="icon-base ti tabler-chevron-right"></i>', current + 1, current === pageCount, false);
                }
                render();
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    @await Html.PartialAsync("_Notifications")
</body>
</html>
