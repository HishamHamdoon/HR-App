@{
    ViewData["Title"] = "Dashboard";
    Layout = "_VuexyLayout";
}

<div class="row g-6 mb-6">
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between">
                    <div class="content-left">
                        <span class="text-heading">@L["TotalEmployees"]</span>
                        <div class="d-flex align-items-center my-1">
                            <h4 class="mb-0 me-2">@ViewBag.Employees</h4>
                        </div>
                        <small class="mb-0">Active workforce</small>
                    </div>
                    <div class="avatar">
                        <span class="avatar-initial rounded bg-label-primary">
                            <i class="icon-base ti tabler-users icon-lg"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between">
                    <div class="content-left">
                        <span class="text-heading">@L["ActiveLeaves"]</span>
                        <div class="d-flex align-items-center my-1">
                            <h4 class="mb-0 me-2">@ViewBag.ActiveLeaves</h4>
                        </div>
                        <small class="mb-0">Approved leaves</small>
                    </div>
                    <div class="avatar">
                        <span class="avatar-initial rounded bg-label-success">
                            <i class="icon-base ti tabler-calendar-check icon-lg"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between">
                    <div class="content-left">
                        <span class="text-heading">@L["Departments"]</span>
                        <div class="d-flex align-items-center my-1">
                            <h4 class="mb-0 me-2">@ViewBag.Departments</h4>
                        </div>
                        <small class="mb-0">Organizational units</small>
                    </div>
                    <div class="avatar">
                        <span class="avatar-initial rounded bg-label-warning">
                            <i class="icon-base ti tabler-building icon-lg"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between">
                    <div class="content-left">
                        <span class="text-heading">@L["PendingApprovals"]</span>
                        <div class="d-flex align-items-center my-1">
                            <h4 class="mb-0 me-2">@ViewBag.Pending</h4>
                        </div>
                        <small class="mb-0">Awaiting action</small>
                    </div>
                    <div class="avatar">
                        <span class="avatar-initial rounded bg-label-danger">
                            <i class="icon-base ti tabler-hourglass icon-lg"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-6">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between">
                <h5 class="card-title mb-0">@L["LeaveStatistics"]</h5>
            </div>
            <div class="card-body">
                <canvas id="leavesChart" height="120"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title mb-0">@L["EmployeeDistribution"]</h5>
            </div>
            <div class="card-body">
                <canvas id="employeeChart" height="120"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-6 mt-2">
    <div class="col-md-3 col-6">
        <a asp-controller="Employees" asp-action="Index" class="text-decoration-none">
            <div class="card text-center">
                <div class="card-body">
                    <span class="avatar-initial rounded-circle bg-label-primary mx-auto mb-2 d-inline-flex" style="width:48px;height:48px;align-items:center;justify-content:center;">
                        <i class="icon-base ti tabler-users icon-md"></i>
                    </span>
                    <h6 class="mb-0">Manage Employees</h6>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a asp-controller="Leaves" asp-action="Index" class="text-decoration-none">
            <div class="card text-center">
                <div class="card-body">
                    <span class="avatar-initial rounded-circle bg-label-success mx-auto mb-2 d-inline-flex" style="width:48px;height:48px;align-items:center;justify-content:center;">
                        <i class="icon-base ti tabler-calendar icon-md"></i>
                    </span>
                    <h6 class="mb-0">Manage Leaves</h6>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a asp-controller="LeavesType" asp-action="Index" class="text-decoration-none">
            <div class="card text-center">
                <div class="card-body">
                    <span class="avatar-initial rounded-circle bg-label-warning mx-auto mb-2 d-inline-flex" style="width:48px;height:48px;align-items:center;justify-content:center;">
                        <i class="icon-base ti tabler-list-details icon-md"></i>
                    </span>
                    <h6 class="mb-0">Leave Types</h6>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a asp-controller="Departments" asp-action="Index" class="text-decoration-none">
            <div class="card text-center">
                <div class="card-body">
                    <span class="avatar-initial rounded-circle bg-label-danger mx-auto mb-2 d-inline-flex" style="width:48px;height:48px;align-items:center;justify-content:center;">
                        <i class="icon-base ti tabler-building icon-md"></i>
                    </span>
                    <h6 class="mb-0">Departments</h6>
                </div>
            </div>
        </a>
    </div>
</div>

@section Scripts {
    <script src="/vuexy/assets/vendor/libs/chartjs/chartjs.js"></script>
    <script>
        (function () {
            var charts = @Html.Raw(ViewBag.ChartsJson ?? "null");
            var palette = ['#7367f0', '#28c76f', '#ff9f43', '#ea5455', '#00cfe8', '#9e69fd', '#f8d66d'];

            var leaveLabels = (charts && charts.leavesPerMonth) ? charts.leavesPerMonth.map(function (x) { return x.label; }) : [];
            var leaveData = (charts && charts.leavesPerMonth) ? charts.leavesPerMonth.map(function (x) { return x.count; }) : [];
            var deptLabels = (charts && charts.employeesPerDepartment) ? charts.employeesPerDepartment.map(function (x) { return x.label; }) : [];
            var deptData = (charts && charts.employeesPerDepartment) ? charts.employeesPerDepartment.map(function (x) { return x.count; }) : [];

            const leavesEl = document.getElementById('leavesChart');
            if (leavesEl && typeof Chart !== 'undefined') {
                new Chart(leavesEl.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: leaveLabels,
                        datasets: [{
                            label: 'Leaves',
                            data: leaveData,
                            borderColor: '#7367f0',
                            backgroundColor: 'rgba(115,103,240,0.1)',
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
                });
            }

            const empEl = document.getElementById('employeeChart');
            if (empEl && typeof Chart !== 'undefined') {
                new Chart(empEl.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: deptLabels,
                        datasets: [{
                            data: deptData,
                            backgroundColor: deptLabels.map(function (_, i) { return palette[i % palette.length]; })
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }
        })();
    </script>
}
