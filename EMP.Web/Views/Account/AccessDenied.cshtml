@{
    Layout = "_VuexyAuthLayout";
    ViewData["Title"] = L["AccessDenied"].Value;
}

<div class="d-flex flex-column align-items-center justify-content-center text-center py-6">
    <div class="card shadow-lg border-0 p-5" style="max-width: 500px;">
        <div class="text-danger mb-4">
            <i class="icon-base ti tabler-lock" style="font-size:4rem;"></i>
        </div>

        <h4 class="fw-bold text-danger">@L["AccessDenied"]</h4>
        <p class="text-body-secondary mb-4">@L["AccessDeniedMessage"]</p>

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="icon-base ti tabler-home me-1"></i> @L["GoBackHome"]
        </a>
    </div>
</div>
