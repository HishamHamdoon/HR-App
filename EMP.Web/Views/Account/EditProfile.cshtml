@using EMP.Web.Views.ViewModels
@model EditProfileVM
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Edit Profile";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Edit Profile</h4>
    <a asp-action="Profile" class="btn btn-label-secondary">
        <i class="icon-base ti tabler-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <form asp-action="EditProfile" method="post">
                    <div class="row g-5">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input class="form-control" value="@Model.Name" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input class="form-control" value="@Model.Email" disabled />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label">Phone</label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label">Address</label>
                            <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-12 d-flex justify-content-end gap-2">
                            <a asp-action="Profile" class="btn btn-label-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="icon-base ti tabler-device-floppy me-1"></i> Save
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
