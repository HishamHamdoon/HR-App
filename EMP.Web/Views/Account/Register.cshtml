@using Emp.Web.Dtos.Auth
@model LoginRequestDto
@{
    ViewData["Title"] = "Register";
    Layout = "_VuexyAuthLayout";
}

<h4 class="mb-1">Create an account 🚀</h4>
<p class="mb-6">Sign up to get started</p>

<form asp-action="Register" asp-controller="Account" method="post" class="mb-4">
    <div class="mb-6">
        <label asp-for="Username" class="form-label">Username</label>
        <input asp-for="Username" class="form-control" placeholder="Choose a username" autofocus />
    </div>
    <div class="mb-6">
        <label asp-for="Password" class="form-label">Password</label>
        <input asp-for="Password" type="password" class="form-control" placeholder="Choose a password" />
    </div>
    <div class="mb-6">
        <button type="submit" class="btn btn-primary d-grid w-100">Sign up</button>
    </div>
</form>

<p class="text-center mb-0">
    <span>Already have an account?</span>
    <a asp-controller="Account" asp-action="Login"><span>Sign in instead</span></a>
</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
