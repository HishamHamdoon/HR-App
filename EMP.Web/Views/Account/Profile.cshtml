@model UserProfileViewModel
@{
    ViewData["Title"] = "Profile";
    Layout = "_VuexyLayout";
    var name = Model?.Employee?.Name ?? Model?.Name ?? "User";
}

<div class="mb-6">
    <h4 class="mb-0">My Profile</h4>
</div>

<div class="row g-6">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body text-center">
                <div class="avatar avatar-xl mx-auto mb-3">
                    <span class="avatar-initial rounded-circle bg-label-primary" style="font-size:1.5rem;">
                        @(string.IsNullOrEmpty(name) ? "U" : name.Substring(0,1).ToUpper())
                    </span>
                </div>
                <h5 class="mb-0">@name</h5>
                <span class="badge bg-label-primary mt-2">@Model?.Role</span>
                <p class="text-body-secondary mt-2 mb-0">Employee ID: @Model?.EmployeeId</p>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">Details</h5></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-body-secondary fw-normal">Email</dt>
                    <dd class="col-sm-8 fw-medium">@Model?.Email</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Phone</dt>
                    <dd class="col-sm-8 fw-medium">@Model?.Employee?.Phone</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Department</dt>
                    <dd class="col-sm-8"><span class="badge bg-label-info">@Model?.Employee?.DepartmentName</span></dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Manager</dt>
                    <dd class="col-sm-8 fw-medium">@(string.IsNullOrEmpty(Model?.Employee?.Manager) ? "—" : Model.Employee.Manager)</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Country</dt>
                    <dd class="col-sm-8"><span class="badge bg-label-warning">@Model?.Employee?.CountryName</span></dd>
                </dl>
            </div>
        </div>
    </div>
</div>
