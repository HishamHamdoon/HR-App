@model UserProfileViewModel
@{
    ViewData["Title"] = "Profile";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8 col-md-10">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-gradient bg-primary text-white text-center py-4">
                <h3 class="mb-0">👤 User Profile</h3>
            </div>
            <div class="card-body px-4 py-5">
                <div class="text-center mb-5">
                    <i class="fa fa-user-circle fa-7x text-secondary"></i>
                    <h4 class="mt-3">@Model.Employee.Name</h4>
                    <p class="text-muted mb-0">@Model.Role</p>
                    <small class="text-muted">Employee ID: @Model.EmployeeId</small>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light">
                            <label class="fw-bold text-muted">📧 Email</label>
                            <div>@Model.Email</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light">
                            <label class="fw-bold text-muted">📞 Phone</label>
                            <div>@Model.Employee.Phone</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light">
                            <label class="fw-bold text-muted">🏢 Department</label>
                            <div>@Model.Employee.DepartmentName</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light">
                            <label class="fw-bold text-muted">👔 Manager</label>
                            <div>@Model.Employee.Manager</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light">
                            <label class="fw-bold text-muted">🌍 Nationality</label>
                            <div>@Model.Employee.CountryName</div>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-5">
                    <a asp-controller="Account" asp-action="EditProfile" class="btn btn-lg btn-outline-primary px-4">
                        ✏️ Edit Profile
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
