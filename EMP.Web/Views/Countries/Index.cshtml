@using Emp.Web.Models.Dtos
@model List<CountryDto>
@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h2 class="fw-bold text-primary">
        <i class="fa fa-globe"></i> Countries Management
    </h2>
    <a asp-controller="Countries" asp-action="Create" class="btn btn-success shadow-sm">
        <i class="fa fa-plus me-1"></i> Add New Country
    </a>
</div>

@if (Model.Any())
{
    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width: 50px;">#</th>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Status</th>
                    <th class="text-end" style="width: 250px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var country in Model)
                {
                    <tr>
                        <td>@country.Id</td>
                        <td>@country.Name</td>
                        <td>@country.Code</td>
                        <td>
                            @if (country.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group" role="group">
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-controller="Countries"
                                   asp-action="Edit"
                                   asp-route-id="@country.Id"
                                   title="Edit">
                                    <i class="fa fa-edit"></i>
                                </a>

                                <a class="btn btn-sm btn-outline-info"
                                   asp-controller="Countries"
                                   asp-action="Details"
                                   asp-route-id="@country.Id"
                                   title="Details">
                                    <i class="fa fa-info-circle"></i>
                                </a>

                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-country-id="@country.Id"
                                        onclick="showConfirmModal(this)"
                                        title="Delete">
                                    <i class="fa fa-trash"></i>
                                </button>

                                <a class="btn btn-sm btn-outline-warning"
                                   asp-controller="Countries"
                                   asp-action="ToggleStatus"
                                   asp-route-id="@country.Id"
                                   title="@((country.IsActive) ? "Deactivate" : "Activate")">
                                    @if (country.IsActive)
                                    {
                                        <i class="fa fa-ban"></i>
                                    }
                                    else
                                    {
                                        <i class="fa fa-check"></i>
                                    }
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-warning text-center p-4 rounded shadow-sm mt-4">
        <i class="fa fa-exclamation-triangle me-2"></i> No countries found!
    </div>
}

<!-- Confirm Delete Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow rounded-3">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this country?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmYesBtn" class="btn btn-danger">Yes, Delete</button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        let countryIdToDelete = null;

        function showConfirmModal(button) {
            countryIdToDelete = button.getAttribute("data-country-id");

            const modal = new bootstrap.Modal(document.getElementById("confirmModal"));
            modal.show();
        }

        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById("confirmYesBtn").addEventListener("click", async function () {
                if (!countryIdToDelete) return;

                try {
                    const response = await fetch(`/Countries/DeletePost/${countryIdToDelete}`, {
                        method: "POST"
                    });

                    if (response.ok) {
                        location.reload(); // Refresh page after deletion
                    } else {
                        alert("Failed to delete country.");
                    }
                } catch (error) {
                    console.error(error);
                    alert("An error occurred.");
                }
            });
        });
    </script>
}
