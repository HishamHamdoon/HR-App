@using Emp.Web.Models.Dtos
@model List<CountryDto>
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Countries";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-6">
    <div>
        <h4 class="mb-1">Countries</h4>
        <p class="mb-0 text-body-secondary">Manage country list</p>
    </div>
    <a asp-controller="Countries" asp-action="Create" class="btn btn-primary">
        <i class="icon-base ti tabler-plus me-1"></i> Add Country
    </a>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        @if (Model != null && Model.Any())
        {
            <table class="table table-hover border-top" data-paginate="10">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Code</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var country in Model)
                    {
                        <tr>
                            <td>@country.Id</td>
                            <td class="fw-medium">@country.Name</td>
                            <td>@country.Code</td>
                            <td>
                                @if (country.IsActive)
                                {
                                    <span class="badge rounded-pill bg-label-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-label-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a class="btn btn-icon btn-text-secondary rounded-pill" asp-controller="Countries" asp-action="Edit" asp-route-id="@country.Id" title="Edit">
                                        <i class="icon-base ti tabler-edit"></i>
                                    </a>
                                    <a class="btn btn-icon btn-text-secondary rounded-pill" asp-controller="Countries" asp-action="Details" asp-route-id="@country.Id" title="Details">
                                        <i class="icon-base ti tabler-eye"></i>
                                    </a>
                                    <a class="btn btn-icon btn-text-secondary rounded-pill" asp-controller="Countries" asp-action="ToggleStatus" asp-route-id="@country.Id" title="@(country.IsActive ? "Deactivate" : "Activate")">
                                        <i class="icon-base ti @(country.IsActive ? "tabler-ban" : "tabler-check")"></i>
                                    </a>
                                    <button type="button" class="btn btn-icon btn-text-secondary rounded-pill" data-country-id="@country.Id" onclick="showConfirmModal(this)" title="Delete">
                                        <i class="icon-base ti tabler-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center p-6">
                <i class="icon-base ti tabler-world-off mb-2" style="font-size:2.5rem;opacity:.4;"></i>
                <h6 class="mb-0">No countries found</h6>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">Are you sure you want to delete this country?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmYesBtn" class="btn btn-danger">Yes, Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let countryIdToDelete = null;
        function showConfirmModal(button) {
            countryIdToDelete = button.getAttribute("data-country-id");
            new bootstrap.Modal(document.getElementById("confirmModal")).show();
        }
        document.addEventListener("DOMContentLoaded", function () {
            const btn = document.getElementById("confirmYesBtn");
            if (!btn) return;
            btn.addEventListener("click", async function () {
                if (!countryIdToDelete) return;
                try {
                    const response = await fetch(`/Countries/DeletePost/${countryIdToDelete}`, { method: "POST" });
                    if (response.ok) { location.reload(); } else { alert("Failed to delete country."); }
                } catch (e) { console.error(e); alert("An error occurred."); }
            });
        });
    </script>
}
