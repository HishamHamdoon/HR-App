@using Emp.Web.Models.Dtos
@model CountryDto
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Country Details";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Country Details</h4>
    <a asp-action="Index" class="btn btn-label-secondary"><i class="icon-base ti tabler-arrow-left me-1"></i> Back to List</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@Model.Name</h5>
                <span class="badge bg-label-secondary">@Model.Code</span>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-body-secondary fw-normal">Name</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Name</dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Code</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Code</dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-label-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-label-secondary">Inactive</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-end gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="icon-base ti tabler-edit me-1"></i> Edit</a>
            </div>
        </div>
    </div>
</div>
