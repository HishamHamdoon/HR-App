@using EMP.Web.Models.Dtos
@model PaggedLeavTypeVM
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = L["LeaveTypes"].Value;
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-6">
    <div>
        <h4 class="mb-1">@L["LeaveTypes"]</h4>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="icon-base ti tabler-plus me-1"></i> @L["AddLeaveType"]
    </a>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        @if (Model != null && Model.LeaveTypes.Any())
        {
            <table class="table table-hover border-top" data-paginate="10" data-search>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@L["Name"]</th>
                        <th>@L["Note"]</th>
                        <th>Max Days</th>
                        <th>Min Days</th>
                        <th>@L["Attachment"]</th>
                        <th>@L["Status"]</th>
                        <th class="text-end">@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.LeaveTypes)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="fw-medium">@item.Name</td>
                            <td>@item.Note</td>
                            <td>@item.MaxDays</td>
                            <td>@item.MinDays</td>
                            <td>
                                @if (item.IsAttachmentRequired)
                                {
                                    <span class="badge bg-label-warning">Required</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-secondary">Optional</span>
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge rounded-pill bg-label-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-label-danger">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="Edit">
                                        <i class="icon-base ti tabler-edit"></i>
                                    </a>
                                    <a asp-controller="LeavesType" asp-action="Details" asp-route-id="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="Details">
                                        <i class="icon-base ti tabler-eye"></i>
                                    </a>
                                    <form asp-controller="LeavesType" asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0"
                                          onsubmit="return confirm('Delete this leave type?');">
                                        <button type="submit" class="btn btn-icon btn-text-secondary rounded-pill" title="Delete">
                                            <i class="icon-base ti tabler-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center p-6">
                <i class="icon-base ti tabler-list-search mb-2" style="font-size:2.5rem;opacity:.4;"></i>
                <h6 class="mb-0">No leave types found</h6>
            </div>
        }
    </div>
</div>
