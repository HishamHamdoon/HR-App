@using Emp.Web.Dtos
@model UpdateLeaveTypesDto
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Edit Leave Type";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Edit Leave Type</h4>
    <a asp-action="Index" class="btn btn-label-secondary"><i class="icon-base ti tabler-arrow-left me-1"></i> Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-controller="LeavesType" asp-action="Edit" method="post" class="row g-5">
                    <input type="hidden" asp-for="Id" />
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label">Leave Type Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Note" class="form-label">Note</label>
                        <textarea asp-for="Note" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Note" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MaxDays" class="form-label">Maximum Days</label>
                        <input asp-for="MaxDays" type="number" class="form-control" />
                        <span asp-validation-for="MaxDays" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MinDays" class="form-label">Minimum Days</label>
                        <input asp-for="MinDays" type="number" class="form-control" />
                        <span asp-validation-for="MinDays" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check mt-2">
                            <input asp-for="IsAttachmentRequired" class="form-check-input" type="checkbox" />
                            <label asp-for="IsAttachmentRequired" class="form-check-label">Attachment Required</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check mt-2">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>
                    <div class="col-12 d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-label-secondary">Cancel</a>
                        <button type="submit" class="btn btn-success"><i class="icon-base ti tabler-device-floppy me-1"></i> Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
