@using EMP.Web.Models.Dtos
@model LeaveTypesViewDto
@{
    Layout = "_AdminLayout";
}
<div class="container mt-4">
    <div class="card shadow-sm rounded-3">
        <div class="card-header bg-primary text-white">
            <h4><i class="fa fa-info-circle"></i> Leave Type Details</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Note</dt>
                <dd class="col-sm-9">@Model.Note</dd>

                <dt class="col-sm-3">Max Days</dt>
                <dd class="col-sm-9">@Model.MaxDays</dd>

                <dt class="col-sm-3">Min Days</dt>
                <dd class="col-sm-9">@Model.MinDays</dd>

                <dt class="col-sm-3">Attachment Required</dt>
                <dd class="col-sm-9">
                    @if (Model.IsAttachmentRequired)
                    {
                        <span class="badge bg-warning text-dark">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No</span>
                    }
                </dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </dd>
            </dl>
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fa fa-arrow-left"></i> Back
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="fa fa-edit"></i> Edit
            </a>
        </div>
    </div>
</div>
