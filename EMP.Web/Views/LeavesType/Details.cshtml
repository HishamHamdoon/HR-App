@using EMP.Web.Models.Dtos
@model LeaveTypesViewDto
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Leave Type Details";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Leave Type Details</h4>
    <a asp-action="Index" class="btn btn-label-secondary"><i class="icon-base ti tabler-arrow-left me-1"></i> Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">@Model.Name</h5></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-body-secondary fw-normal">Note</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Note</dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Max Days</dt>
                    <dd class="col-sm-8 fw-medium">@Model.MaxDays</dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Min Days</dt>
                    <dd class="col-sm-8 fw-medium">@Model.MinDays</dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Attachment Required</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsAttachmentRequired)
                        {
                            <span class="badge bg-label-warning">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-label-secondary">No</span>
                        }
                    </dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-label-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-label-danger">Inactive</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-end">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="icon-base ti tabler-edit me-1"></i> Edit</a>
            </div>
        </div>
    </div>
</div>
