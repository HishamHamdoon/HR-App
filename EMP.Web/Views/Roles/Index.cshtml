@model List<string>
@{
    ViewData["Title"] = L["Roles"].Value;
    Layout = "_VuexyLayout";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-6">
    <div>
        <h4 class="mb-1">@L["Roles"]</h4>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="icon-base ti tabler-plus me-1"></i> @L["Add"]</a>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        @if (Model != null && Model.Any())
        {
            <table class="table table-hover border-top" data-paginate="10" data-search>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@L["RoleName"]</th>
                        <th class="text-end">@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count(); i++)
                    {
                        <tr>
                            <td>@(i + 1)</td>
                            <td>
                                <span class="d-flex align-items-center">
                                    <span class="avatar avatar-sm me-2">
                                        <span class="avatar-initial rounded-circle bg-label-primary"><i class="icon-base ti tabler-shield"></i></span>
                                    </span>
                                    <span class="fw-medium">@Model.ElementAt(i)</span>
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <form asp-action="Delete" method="post" class="m-0"
                                          onsubmit="return confirm('Delete the @Model.ElementAt(i) role?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="name" value="@Model.ElementAt(i)" />
                                        <button type="submit" class="btn btn-icon btn-text-secondary rounded-pill" title="Delete">
                                            <i class="icon-base ti tabler-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center p-6">
                <i class="icon-base ti tabler-shield-off mb-2" style="font-size:2.5rem;opacity:.4;"></i>
                <h6 class="mb-0">No roles found</h6>
            </div>
        }
    </div>
</div>
