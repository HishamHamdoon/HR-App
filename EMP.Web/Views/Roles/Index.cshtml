@model List<string>
@{
    ViewData["Title"] = "Roles";
    Layout = "_VuexyLayout";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-6">
    <div>
        <h4 class="mb-1">Roles &amp; Permissions</h4>
        <p class="mb-0 text-body-secondary">Manage application roles</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="icon-base ti tabler-plus me-1"></i> Create New Role</a>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        @if (Model != null && Model.Any())
        {
            <table class="table table-hover border-top" data-paginate="10">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Role Name</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count(); i++)
                    {
                        <tr>
                            <td>@(i + 1)</td>
                            <td>
                                <span class="d-flex align-items-center">
                                    <span class="avatar avatar-sm me-2">
                                        <span class="avatar-initial rounded-circle bg-label-primary"><i class="icon-base ti tabler-shield"></i></span>
                                    </span>
                                    <span class="fw-medium">@Model.ElementAt(i)</span>
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="Edit" asp-route-name="@Model.ElementAt(i)" class="btn btn-icon btn-text-secondary rounded-pill" title="Edit">
                                        <i class="icon-base ti tabler-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-name="@Model.ElementAt(i)" class="btn btn-icon btn-text-secondary rounded-pill" title="Delete">
                                        <i class="icon-base ti tabler-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center p-6">
                <i class="icon-base ti tabler-shield-off mb-2" style="font-size:2.5rem;opacity:.4;"></i>
                <h6 class="mb-0">No roles found</h6>
            </div>
        }
    </div>
</div>
