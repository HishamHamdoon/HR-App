@using static EMP.Web.Controllers.RolesController
@model RoleDto
@{
    ViewData["Title"] = "Create Role";
    Layout = "_VuexyLayout";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Create New Role</h4>
    <a asp-action="Index" class="btn btn-label-secondary"><i class="icon-base ti tabler-arrow-left me-1"></i> Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post" class="row g-5">
                    <div class="col-12">
                        <label for="roleName" class="form-label">Role Name</label>
                        <input id="roleName" name="roleName" class="form-control" placeholder="e.g. Manager" />
                    </div>
                    <div class="col-12 d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-label-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary"><i class="icon-base ti tabler-device-floppy me-1"></i> Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
