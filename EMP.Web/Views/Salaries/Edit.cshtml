@using EMP.Web.Models.Dtos
@model SalaryDto

@{
    ViewData["Title"] = "Edit Salary";
    Layout = "_AdminLayout";

}

    <h2>Edit Salary</h2>
    <hr />

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="EmployeeId" />

        <div class="mb-3">
            <label asp-for="EmployeeName" class="form-label"></label>
            <input asp-for="EmployeeName" class="form-control" readonly />
            <span asp-validation-for="EmployeeName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="BasicSalary" class="form-label"></label>
            <input asp-for="BasicSalary" class="form-control" />
            <span asp-validation-for="BasicSalary" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Allowances" class="form-label"></label>
            <input asp-for="Allowances" class="form-control" />
            <span asp-validation-for="Allowances" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Deductions" class="form-label"></label>
            <input asp-for="Deductions" class="form-control" />
            <span asp-validation-for="Deductions" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NetSalary" class="form-label"></label>
            <input asp-for="NetSalary" class="form-control" readonly />
            <span asp-validation-for="NetSalary" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EffectiveDate" class="form-label"></label>
            <input asp-for="EffectiveDate" type="date" class="form-control" />
            <span asp-validation-for="EffectiveDate" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fa fa-arrow-left"></i> Back
            </a>
            <button type="submit" class="btn btn-success">
                <i class="fa fa-save"></i> Save Changes
            </button>
        </div>
    </form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
