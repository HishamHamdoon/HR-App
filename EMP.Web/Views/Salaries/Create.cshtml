@model EMP.Web.Models.Dtos.CreateSalaryDto
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Create Salary";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Create Salary</h4>
    <a asp-action="Index" class="btn btn-label-secondary"><i class="icon-base ti tabler-arrow-left me-1"></i> Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post" class="row g-5">
                    <div asp-validation-summary="All" class="text-danger col-12"></div>
                    <div class="col-12">
                        <label asp-for="EmployeeId" class="form-label">Employee</label>
                        <select asp-for="EmployeeId" class="form-select" asp-items="@ViewBag.Employees">
                            <option value="">-- Select Employee --</option>
                        </select>
                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="BasicSalary" class="form-label">Basic Salary</label>
                        <input asp-for="BasicSalary" class="form-control" placeholder="e.g. 5000" />
                        <span asp-validation-for="BasicSalary" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Allowances" class="form-label">Allowances</label>
                        <input asp-for="Allowances" class="form-control" placeholder="e.g. 500" />
                        <span asp-validation-for="Allowances" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Deductions" class="form-label">Deductions</label>
                        <input asp-for="Deductions" class="form-control" placeholder="e.g. 200" />
                        <span asp-validation-for="Deductions" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EffectiveDate" class="form-label">Effective Date</label>
                        <input asp-for="EffectiveDate" type="date" class="form-control" />
                        <span asp-validation-for="EffectiveDate" class="text-danger"></span>
                    </div>
                    <div class="col-12 d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-label-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary"><i class="icon-base ti tabler-device-floppy me-1"></i> Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
