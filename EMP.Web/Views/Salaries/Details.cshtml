@using EMP.Web.Models.Dtos
@model SalaryDto
@{
    ViewData["Title"] = "Salary Details";
    Layout = "_VuexyLayout";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Salary Details</h4>
    <a asp-action="Index" class="btn btn-label-secondary"><i class="icon-base ti tabler-arrow-left me-1"></i> Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">@Model.EmployeeName</h5></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-body-secondary fw-normal">Basic Salary</dt>
                    <dd class="col-sm-8 fw-medium">@Model.BasicSalary.ToString("C")</dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Allowances</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Allowances.ToString("C")</dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Deductions</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Deductions.ToString("C")</dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Net Salary</dt>
                    <dd class="col-sm-8 fw-bold text-success">@Model.NetSalary.ToString("C")</dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Effective Date</dt>
                    <dd class="col-sm-8 fw-medium">@Model.EffectiveDate.ToString("yyyy-MM-dd")</dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-end">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="icon-base ti tabler-edit me-1"></i> Edit</a>
            </div>
        </div>
    </div>
</div>
