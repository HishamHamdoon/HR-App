@using EMP.Web.Models.Dtos
@model IEnumerable<SalaryDto>

@{
    ViewData["Title"] = "Salaries";
    Layout = "_AdminLayout";

}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Salaries</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa fa-plus"></i> Add Salary
        </a>
    </div>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Employee</th>
                <th>Basic Salary</th>
                <th>Allowances</th>
                <th>Deductions</th>
                <th>Net Salary</th>
                <th>Effective Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                var index = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td>@index</td>
                        <td>@item.EmployeeName</td>
                        <td>@item.BasicSalary.ToString("C")</td>
                        <td>@item.Allowances.ToString("C")</td>
                        <td>@item.Deductions.ToString("C")</td>
                        <td>@item.NetSalary.ToString("C")</td>
                        <td>@item.EffectiveDate.ToShortDateString()</td>
                        <td>
                            <a asp-action="Details" asp-route-salaryId="@item.Id" class="btn btn-sm btn-info">
                                <i class="fa fa-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-salaryId="@item.Id" class="btn btn-sm btn-warning">
                                <i class="fa fa-edit"></i>
                            </a>
                        <a asp-controller="Salaries" asp-action="Delete" asp-route-salaryId="@item.Id" class="btn btn-sm btn-danger">
                                <i class="fa fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                    index++;
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">No salary records found.</td>
                </tr>
            }
        </tbody>
    </table>
