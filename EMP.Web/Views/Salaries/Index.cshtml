@using EMP.Web.Models.Dtos
@model IEnumerable<SalaryDto>
@{
    ViewData["Title"] = "Salaries";
    Layout = "_VuexyLayout";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-6">
    <div>
        <h4 class="mb-1">Salaries</h4>
        <p class="mb-0 text-body-secondary">Employee compensation records</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="icon-base ti tabler-plus me-1"></i> Add Salary</a>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        <table class="table table-hover border-top" data-paginate="10">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Employee</th>
                    <th>Basic</th>
                    <th>Allowances</th>
                    <th>Deductions</th>
                    <th>Net</th>
                    <th>Effective</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    var index = 1;
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@index</td>
                            <td class="fw-medium">@item.EmployeeName</td>
                            <td>@item.BasicSalary.ToString("C")</td>
                            <td>@item.Allowances.ToString("C")</td>
                            <td>@item.Deductions.ToString("C")</td>
                            <td class="fw-medium">@item.NetSalary.ToString("C")</td>
                            <td>@item.EffectiveDate.ToShortDateString()</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="Details" asp-route-salaryId="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="Details">
                                        <i class="icon-base ti tabler-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-salaryId="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="Edit">
                                        <i class="icon-base ti tabler-edit"></i>
                                    </a>
                                    <a asp-controller="Salaries" asp-action="Delete" asp-route-salaryId="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="Delete"
                                       onclick="return confirm('Delete this salary record?');">
                                        <i class="icon-base ti tabler-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        index++;
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-body-secondary py-4">No salary records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
