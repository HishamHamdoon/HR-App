@using EMP.Web.Models.Dtos
@model IEnumerable<SalaryDto>
@{
    ViewData["Title"] = L["Salaries"].Value;
    Layout = "_VuexyLayout";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-6">
    <div>
        <h4 class="mb-1">@L["Salaries"]</h4>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="icon-base ti tabler-plus me-1"></i> @L["AddSalary"]</a>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        <table class="table table-hover border-top" data-paginate="10" data-search>
            <thead>
                <tr>
                    <th>#</th>
                    <th>@L["Employee"]</th>
                    <th>@L["Basic"]</th>
                    <th>@L["Allowances"]</th>
                    <th>@L["Deductions"]</th>
                    <th>@L["Net"]</th>
                    <th>@L["Effective"]</th>
                    <th class="text-end">@L["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    var index = 1;
                    foreach (var item in Model)
                    {
                        <tr data-href="@Url.Action("Details", new { salaryId = item.Id })">
                            <td>@index</td>
                            <td class="fw-medium">@item.EmployeeName</td>
                            <td>@item.BasicSalary.ToString("C")</td>
                            <td>@item.Allowances.ToString("C")</td>
                            <td>@item.Deductions.ToString("C")</td>
                            <td class="fw-medium">@item.NetSalary.ToString("C")</td>
                            <td>@item.EffectiveDate.ToShortDateString()</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="Details" asp-route-salaryId="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="@L["Details"]">
                                        <i class="icon-base ti tabler-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-salaryId="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="@L["Edit"]">
                                        <i class="icon-base ti tabler-edit"></i>
                                    </a>
                                    <a asp-controller="Salaries" asp-action="Delete" asp-route-salaryId="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="@L["Delete"]"
                                       onclick="return confirm('Delete this salary record?');">
                                        <i class="icon-base ti tabler-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        index++;
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-body-secondary py-4">@L["NoRecords"]</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
