@using Emp.Web.Dtos.JobTitle
@model IEnumerable<JobTitleViewDto>
@{
    ViewData["Title"] = "Job Titles";
    Layout = "_VuexyLayout";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-6">
    <div>
        <h4 class="mb-1">Job Titles</h4>
        <p class="mb-0 text-body-secondary">Roles and their base salaries</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="icon-base ti tabler-plus me-1"></i> Add Job Title</a>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        <table class="table table-hover border-top" data-paginate="10">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Main Salary</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td class="fw-medium">@item.Title</td>
                            <td>@item.Description</td>
                            <td>@item.MainSalary.ToString("N2")</td>
                            <td>@item.CreatedDate.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="Edit">
                                        <i class="icon-base ti tabler-edit"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="Details">
                                        <i class="icon-base ti tabler-eye"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0"
                                          onsubmit="return confirm('Delete this job title?');">
                                        <button type="submit" class="btn btn-icon btn-text-secondary rounded-pill" title="Delete">
                                            <i class="icon-base ti tabler-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-body-secondary py-4">No job titles found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
