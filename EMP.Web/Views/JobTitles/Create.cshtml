@using Emp.Api.Dtos.JobTitleDto
@model JobTitleViewDto
@{
    ViewData["Title"] = "Create Job Title";
    Layout = "_VuexyLayout";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Create Job Title</h4>
    <a asp-action="Index" class="btn btn-label-secondary"><i class="icon-base ti tabler-arrow-left me-1"></i> Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post" class="row g-5">
                    <div class="col-md-6">
                        <label asp-for="Title" class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Job title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MainSalary" class="form-label">Main Salary</label>
                        <input asp-for="MainSalary" type="number" step="0.01" class="form-control" placeholder="Base salary" />
                        <span asp-validation-for="MainSalary" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Description"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="col-12 d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-label-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary"><i class="icon-base ti tabler-device-floppy me-1"></i> Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
