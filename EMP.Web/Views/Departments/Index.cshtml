@using Emp.Web.Dtos
@model List<DepartmentDto>

@{
    Layout = "_AdminLayout";
}

@* <div class="container mt-4"> *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Departments</h2>
        <a asp-controller="Departments" asp-action="Create" class="btn btn-success">
            <i class="fa fa-plus"></i> Add Department
        </a>
    <a asp-controller="Reports" asp-action="DepartmentReport" class="btn btn-outline-primary   px-4 py-2 d-flex align-items-center shadow-sm btn-lg">
        <i class="fa fa-download me-2"></i> Export PDF
    </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">Department Name</th>
                        <th scope="col" style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-controller="Departments" asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-info" title="View Details">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                    <a asp-controller="Departments" asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary" title="Edit Department">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                    <a asp-controller="Departments" asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger" title="Delete Department">
                                        <i class="fa fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            No departments found. Click <strong>"Add Department"</strong> to create one.
        </div>
    }
@* </div> *@
