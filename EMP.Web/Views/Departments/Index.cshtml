@using Emp.Web.Dtos
@model List<DepartmentDto>
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = L["Departments"].Value;
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-6">
    <div>
        <h4 class="mb-1">@L["Departments"]</h4>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Departments" asp-action="Create" class="btn btn-primary">
            <i class="icon-base ti tabler-plus me-1"></i> @L["AddDepartment"]
        </a>
        <a asp-controller="Reports" asp-action="DepartmentReport" class="btn btn-label-danger">
            <i class="icon-base ti tabler-file-type-pdf me-1"></i> @L["ExportPdf"]
        </a>
    </div>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        @if (Model != null && Model.Any())
        {
            <table class="table table-hover border-top" data-paginate="10" data-search>
                <thead>
                    <tr>
                        <th>@L["Name"]</th>
                        <th class="text-end">@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr data-href="@Url.Action("Details", new { id = item.Id })">
                            <td class="fw-medium">@item.Name</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a asp-controller="Departments" asp-action="Details" asp-route-id="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="@L["Details"]">
                                        <i class="icon-base ti tabler-eye"></i>
                                    </a>
                                    <a asp-controller="Departments" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-text-secondary rounded-pill" title="@L["Edit"]">
                                        <i class="icon-base ti tabler-edit"></i>
                                    </a>
                                    <form asp-controller="Departments" asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0"
                                          onsubmit="return confirm('Delete this department?');">
                                        <button type="submit" class="btn btn-icon btn-text-secondary rounded-pill" title="@L["Delete"]">
                                            <i class="icon-base ti tabler-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center p-6">
                <i class="icon-base ti tabler-building mb-2" style="font-size:2.5rem;opacity:.4;"></i>
                <h6 class="mb-0">No departments found</h6>
            </div>
        }
    </div>
</div>
