@using Emp.Web.Dtos
@model DepartmentDto
@{
    ViewData["Title"] = "Create Department";
    Layout = "_VuexyLayout";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Create Department</h4>
    <a asp-action="Index" class="btn btn-label-secondary"><i class="icon-base ti tabler-arrow-left me-1"></i> Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post" class="row g-5">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label">Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Department name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Location" class="form-label">Location</label>
                        <input asp-for="Location" class="form-control" placeholder="Location" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>
                    <div class="col-12 d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-label-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary"><i class="icon-base ti tabler-device-floppy me-1"></i> Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
