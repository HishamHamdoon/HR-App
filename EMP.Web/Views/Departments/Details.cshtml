@using Emp.Web.Dtos
@model DepartmentDto
@{
    ViewData["Title"] = "Department Details";
    Layout = "_VuexyLayout";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Department Details</h4>
    <a asp-action="Index" class="btn btn-label-secondary"><i class="icon-base ti tabler-arrow-left me-1"></i> Back to List</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">@Model.Name</h5></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-body-secondary fw-normal">ID</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Id</dd>
                    <dt class="col-sm-4 text-body-secondary fw-normal">Name</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Name</dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-end gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="icon-base ti tabler-edit me-1"></i> Edit</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="m-0">
                    <button type="submit" class="btn btn-label-danger" onclick="return confirm('Delete this department?');">
                        <i class="icon-base ti tabler-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
