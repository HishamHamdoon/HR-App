@using Emp.Web.Dtos
@model TerminationDto
@{
    ViewData["Title"] = "Terminate Employee";
    Layout = "_VuexyLayout";
    var employeeList = ViewBag.Employees as List<Emp.Api.Models.Employee> ?? new List<Emp.Api.Models.Employee>();
    var selectedEmployeeId = Model?.EmployeeId;
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Terminate Employee</h4>
    <a asp-controller="Employees" asp-action="Index" class="btn btn-label-secondary"><i class="icon-base ti tabler-arrow-left me-1"></i> Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header"><h5 class="mb-0 text-danger">Termination Details</h5></div>
            <div class="card-body">
                <form method="post" asp-controller="Employees" asp-action="Terminate" class="row g-5">
                    <div asp-validation-summary="ModelOnly" class="text-danger col-12 mb-0"></div>
                    <input hidden asp-for="Id" />
                    <div class="col-12">
                        <label asp-for="EmployeeId" class="form-label">Employee</label>
                        @if (selectedEmployeeId.HasValue && selectedEmployeeId.Value > 0)
                        {
                            var selEmp = employeeList.FirstOrDefault(e => e.Id == selectedEmployeeId.Value);
                            <input type="hidden" asp-for="EmployeeId" />
                            <input type="text" class="form-control" value="@(selEmp?.Name ?? $"Employee #{selectedEmployeeId}")" disabled />
                        }
                        else
                        {
                            <select asp-for="EmployeeId" asp-items="@(new SelectList(employeeList, "Id", "Name"))" class="form-select">
                                <option value="">-- Select Employee --</option>
                            </select>
                        }
                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TerminationType" class="form-label">Termination Type</label>
                        <select asp-for="TerminationType" class="form-select">
                            <option value="">Select Type</option>
                            <option value="Voluntary">Voluntary (resignation)</option>
                            <option value="Involuntary">Involuntary (dismissal / layoff)</option>
                            <option value="Retirement">Retirement</option>
                            <option value="ContractEnd">Contract End</option>
                        </select>
                        <span asp-validation-for="TerminationType" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DateTerminated" class="form-label">Termination Date</label>
                        <input asp-for="DateTerminated" type="date" disabled value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="TerminationReason" class="form-label">Reason</label>
                        <textarea asp-for="TerminationReason" class="form-control" rows="4" placeholder="Enter reason for termination"></textarea>
                        <span asp-validation-for="TerminationReason" class="text-danger"></span>
                    </div>
                    <div class="col-12 d-flex justify-content-end gap-2">
                        <a asp-controller="Employees" asp-action="Index" class="btn btn-label-secondary">Cancel</a>
                        <button type="submit" class="btn btn-danger"><i class="icon-base ti tabler-user-x me-1"></i> Terminate Employee</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
