@using EMP.Web.Views.ViewModels
@using Emp.Web.Models.Dtos
@model EmployeeFormViewModel

@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Edit Employee";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Edit Employee</h4>
    <a asp-action="Index" class="btn btn-label-secondary">
        <i class="icon-base ti tabler-arrow-left me-1"></i> Back
    </a>
</div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Employee.Id" />
    <div class="row g-6">
        <div class="col-12">
            <div class="card">
                <div class="card-header"><h5 class="mb-0">Personal Information</h5></div>
                <div class="card-body">
                    <div class="row g-5">
                        <div class="col-md-6">
                            <label asp-for="Employee.Name" class="form-label">Name</label>
                            <input asp-for="Employee.Name" class="form-control" />
                            <span asp-validation-for="Employee.Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Employee.Email" class="form-label">Email</label>
                            <input asp-for="Employee.Email" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Employee.Phone" class="form-label">Phone</label>
                            <input asp-for="Employee.Phone" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Employee.Address" class="form-label">Address</label>
                            <input asp-for="Employee.Address" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Employee.BirthDate" class="form-label">Birth Date</label>
                            <input asp-for="Employee.BirthDate" type="date" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-header"><h5 class="mb-0">Job Information</h5></div>
                <div class="card-body">
                    <div class="row g-5">
                        <div class="col-md-6">
                            <label asp-for="Employee.HireDate" class="form-label">Hire Date</label>
                            <input asp-for="Employee.HireDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Employee.LeavingDate" class="form-label">Leaving Date</label>
                            <input asp-for="Employee.LeavingDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Employee.DepartmentId" class="form-label">Department</label>
                            <select asp-for="Employee.DepartmentId" asp-items="@(new SelectList(Model.Departments, "Id", "Name", Model.Employee.DepartmentId))" class="form-select">
                                <option value="">-- Select Department --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Employee.SectionId" class="form-label">Section</label>
                            <select asp-for="Employee.SectionId" asp-items="@(new SelectList(Model.Sections, "Id", "Name", Model.Employee.SectionId))" class="form-select">
                                <option value="">-- Select Section --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Employee.JobTitleId" class="form-label">Job Title</label>
                            <select asp-for="Employee.JobTitleId" asp-items="@(new SelectList(Model.JobTitles, "Id", "Title", Model.Employee.JobTitleId))" class="form-select">
                                <option value="">-- Select Job Title --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Employee.CountryId" class="form-label">Country</label>
                            <select asp-for="Employee.CountryId" asp-items="@(new SelectList(Model.Countries, "Id", "Name", Model.Employee.CountryId))" class="form-select">
                                <option value="">-- Select Country --</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="Employee.IsActive" class="form-check-input" />
                                <label asp-for="Employee.IsActive" class="form-check-label">Is Active</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 d-flex justify-content-end gap-2">
            <a asp-action="Index" class="btn btn-label-secondary">Cancel</a>
            <button type="submit" class="btn btn-success"><i class="icon-base ti tabler-device-floppy me-1"></i> Save Changes</button>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
