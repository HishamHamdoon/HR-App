@model EmployeeVM
@using EMP.Web.Views.ViewModels
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Employee Details";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Employee Details</h4>
    <div class="d-flex gap-2">
        @if (Model.isActive)
        {
            <a class="btn btn-label-danger" asp-controller="Employees" asp-action="Terminate" asp-route-employeeId="@Model.Id">
                <i class="icon-base ti tabler-user-x me-1"></i> Terminate
            </a>
        }
        else
        {
            <span class="badge bg-label-danger align-self-center">
                Terminated@(Model.LeavingDate.HasValue ? $" on {Model.LeavingDate.Value:dd MMM yyyy}" : "")
            </span>
            <form asp-controller="Employees" asp-action="Reactivate" method="post" class="m-0"
                  onsubmit="return confirm('Reactivate this employee and restore their login?');">
                <input type="hidden" name="employeeId" value="@Model.Id" />
                <button type="submit" class="btn btn-label-success">
                    <i class="icon-base ti tabler-user-check me-1"></i> Reactivate
                </button>
            </form>
        }
        <a class="btn btn-label-secondary" asp-controller="Employees" asp-action="Index">
            <i class="icon-base ti tabler-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="row g-6">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body text-center">
                <div class="avatar avatar-xl mx-auto mb-3">
                    <span class="avatar-initial rounded-circle bg-label-primary" style="font-size:1.5rem;">
                        @(string.IsNullOrEmpty(Model.Name) ? "?" : Model.Name.Substring(0,1).ToUpper())
                    </span>
                </div>
                <h5 class="mb-0">@Model.Name</h5>
                <span class="text-body-secondary">@Model.JobTitleTitle</span>
                <div class="mt-3">
                    @if (Model.isActive)
                    {
                        <span class="badge rounded-pill bg-label-success">Active</span>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-label-danger">Inactive</span>
                    }
                </div>
            </div>
            <div class="card-footer d-flex justify-content-center gap-2">
                <a class="btn btn-sm btn-primary" asp-controller="Employees" asp-action="Edit" asp-route-employeeId="@Model.Id">
                    <i class="icon-base ti tabler-edit me-1"></i> Edit
                </a>
                <a class="btn btn-sm btn-label-warning" asp-action="Terminate">
                    <i class="icon-base ti tabler-user-x me-1"></i> Terminate
                </a>
                <form asp-controller="Employees" asp-action="DeleteEmployee" method="post"
                      onsubmit="return confirm('Are you sure you want to delete this employee?');">
                    <input type="hidden" name="employeeIdToDelete" value="@Model.Id" />
                    <button type="submit" class="btn btn-sm btn-label-danger">
                        <i class="icon-base ti tabler-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">Details</h5></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-body-secondary fw-normal">Employee ID</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Id</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Email</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Email</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Phone</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Phone</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Department</dt>
                    <dd class="col-sm-8"><span class="badge bg-label-info">@Model.DepartmentName</span></dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Job Title</dt>
                    <dd class="col-sm-8"><span class="badge bg-label-success">@Model.JobTitleTitle</span></dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Manager</dt>
                    <dd class="col-sm-8 fw-medium">@(string.IsNullOrEmpty(Model.Manager) ? "—" : Model.Manager)</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Country</dt>
                    <dd class="col-sm-8"><span class="badge bg-label-warning">@Model.CountryName</span></dd>
                </dl>
            </div>
        </div>
    </div>
</div>
