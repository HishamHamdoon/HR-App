@model PagedEmployeesVM
@using EMP.Web.Models.Dtos
@using EMP.Web.Views.ViewModels

@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center  mb-4 flex-wrap gap-3">
    <h2 class="fw-bold text-primary m-0">
        <i class="fa-solid fa-users"></i> Employees
    </h2>

    <div class="d-flex flex-wrap gap-2">

        <!-- Add New Employee -->
        <a asp-controller="Employees" asp-action="Create" class="btn btn-outline-success   px-4 py-2 d-flex align-items-center shadow-sm btn-lg">
            <i class="fa fa-plus me-2"></i> Add Employee
        </a>

        <!-- Import Excel -->
        <a asp-controller="Employees" asp-action="ImportExcel" class="btn btn-outline-warning   px-4 py-2 d-flex align-items-center shadow-sm btn-lg">
            <i class="fa fa-file-excel me-2"></i> Export Excel
        </a>

        <!-- Download Report -->
        <a asp-controller="Reports" asp-action="EmployeeReport" class="btn btn-outline-primary   px-4 py-2 d-flex align-items-center shadow-sm btn-lg">
            <i class="fa fa-download me-2"></i> Export PDF
        </a>
        
        
    </div>
</div>


@if (Model.Employees.Any())
{
    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Job Title</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Department</th>
                    <th>Manager</th>
                    <th>Country</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var employee in Model.Employees)
                {
                    <tr>
                        <td>@employee.Id</td>
                        <td>@employee.Name</td>
                        <td>@employee.JobTitleTitle</td>
                        <td>@employee.Email</td>
                        <td>@employee.Phone</td>
                        <td>@employee.DepartmentName</td>
                        <td>@employee.Manager</td>
                        <td>@employee.CountryName</td>
                        <td>
                            @if (employee.isActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Employees" asp-action="Edit" asp-route-employeeId="@employee.Id">
                                <i class="fa fa-edit"></i>
                            </a>
                            <a class="btn btn-sm btn-outline-info" asp-controller="Employees" asp-action="EmployeeDetails" asp-route-employeeId="@employee.Id">
                                <i class="fa fa-info-circle"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-employee-id="@employee.Id" onclick="showConfirmModal(this)">
                                <i class="fa fa-trash"></i>
                            </button>
                            <button type="button"
                                    class="btn btn-sm btn-outline-warning"
                                    onclick="toggleEmployeeStatus(@employee.Id, @(employee.isActive.ToString().ToLower()))">
                                @if (!employee.isActive)
                                {
                                    <i class="fa fa-check"></i>
                                }
                                else
                                {
                                    <i class="fa fa-ban"></i>
                                }
                            </button>
                            <!-- New Set Manager Button -->
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    onclick="openSetManagerModal(@employee.Id)">
                                <i class="fa fa-user-tie"></i> Set Manager
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <!-- Set Manager Modal -->
    <div class="modal fade" id="setManagerModal" tabindex="-1" aria-labelledby="setManagerModalLabel">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="setManagerModalLabel">Set Manager</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="setManagerForm">
                        <input type="hidden" id="employeeId" />

                        <div class="mb-3">
                            <label for="managerId" class="form-label">Select Manager</label>
                            <select id="managerId" class="form-select">
                                <option value="">-- Choose Manager --</option>
                                @foreach (var manager in Model.Employees)
                                {
                                    <option value="@manager.Id">@manager.Name</option>
                                }
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="setManager()">Save</button>
                </div>
            </div>
        </div>
    </div>
    <!--confirm Delete Modal-->
    <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete this employee?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                     <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button> 
                </div>
            </div>
        </div>
    </div>
    <!--confirm Delete Modal-->
}
else
{
    <div class="alert alert-warning text-center p-4 rounded-3 shadow-sm">
        <i class="fa-solid fa-triangle-exclamation fa-lg"></i> No employees found!
    </div>
}

<!-- Pagination Controls -->
<nav class="mt-4">
    <ul class="pagination justify-content-center">
        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
        </li>

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
            </li>
        }

        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">Next</a>
        </li>
    </ul>
</nav>
@section Scripts {
    <script>
        function openSetManagerModal(employeeId) {
            document.getElementById("employeeId").value = employeeId;
            var modal = new bootstrap.Modal(document.getElementById("setManagerModal"));
            modal.show();
        }

        async function setManager() {
            const employeeId = document.getElementById("employeeId").value;
            const managerId = document.getElementById("managerId").value;

            if (!managerId) {
                alert("Please select a manager.");
                return;
            }

            try {
                const response = await fetch(`Employees/SetManager?employeeId=${employeeId}&managerId=${managerId}`, {
                    method: "Post"
                });

                if (response.ok) {
                    location.reload(); // refresh table
                } else {
                    alert("Failed to set manager.");
                }
            } catch (error) {
                console.error(error);
                alert("An error occurred while setting the manager.");
            }
        }
           async function toggleEmployeeStatus(employeeId, isActive) {
               try {
                   const response = await fetch(`/Employees/ActiveDeActiveEmployee?employeeId=${employeeId}`, {
                       method: "POST" // your controller method should be [HttpPost]
                   });

                   if (response.ok) {
                       // ✅ Option 1: Just refresh the page
                       location.reload();

                   } else {
                       alert("Failed to update employee status.");
                   }
               } catch (error) {
                   console.error(error);
                   alert("An error occurred while updating the status.");
               }
           }
           //delete employee function
                   let employeeIdToDelete = null;

        // Show the confirm modal
        function showConfirmModal(button) {
            employeeIdToDelete = button.getAttribute("data-employee-id");

            const modalElement = document.getElementById('confirmDeleteModal');
            const modal = new bootstrap.Modal(modalElement);
            modal.show();
        }

        // AJAX function to delete employee
        async function confirmDelete() {
            if (!employeeIdToDelete) return;

            try {
                const response = await fetch(`/Employees/DeleteEmployee?employeeIdToDelete=${employeeIdToDelete}`, {
                    method: "POST",
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                });

                const data = await response.json();

                if (data.success) {
                    // Remove the row from the table
                    location.reload(); // refresh table and server data
                    const row = document.querySelector(`[data-employee-row="${employeeIdToDelete}"]`);
                    if (row) row.remove();
                    // Hide the modal
                    const modalElement = document.getElementById('confirmDeleteModal');
                    let modal = bootstrap.Modal.getInstance(modalElement);
                    if (!modal) modal = new bootstrap.Modal(modalElement);
                    modal.hide();
                    employeeIdToDelete = null;
                } else {
                    alert(data.message || "Failed to delete employee.");
                }
            } catch (error) {
                console.error(error);
                alert("An error occurred while deleting the employee.");
            }
        }

        // Attach click listener after DOM loads
        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById("confirmDeleteBtn").addEventListener("click", confirmDelete);
        });

       


    </script>
   
}
@{
    await Html.RenderPartialAsync("_Notifications");
}