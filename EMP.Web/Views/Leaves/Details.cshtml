@model Emp.Web.Dtos.ViewLeaveDto
@{
    Layout = "_AdminLayout";
}
<div class="card shadow-lg border-0 rounded-3">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">
            <i class="fa-solid fa-file-alt"></i> Leave Details
        </h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Employee</dt>
            <dd class="col-sm-9">@Model.EmployeeName</dd>

            <dt class="col-sm-3">Leave Type</dt>
            <dd class="col-sm-9">@Model.LeaveName</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("dd-MMM-yyyy")</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate?.ToString("dd-MMM-yyyy")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Status == "Approved")
                {
                    <span class="badge bg-success">@Model.Status</span>
                }
                else if (Model.Status == "Pending")
                {
                    <span class="badge bg-warning">@Model.Status</span>
                }
                else
                {
                    <span class="badge bg-danger">@Model.Status</span>
                }
            </dd>
        </dl>
    </div>
    <div class="card-footer text-end">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fa fa-arrow-left"></i> Back to List
        </a>
        <a asp-action="Edit" asp-route-leaveId="@Model.Id" class="btn btn-primary">
            <i class="fa fa-edit"></i> Edit
        </a>
        <a asp-action="Delete" asp-route-leaveId="@Model.Id" class="btn btn-danger">
            <i class="fa fa-trash"></i> Delete
        </a>
    </div>
</div>
