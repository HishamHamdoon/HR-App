@model Emp.Web.Dtos.ViewLeaveDto
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Leave Details";
    var status = Model.Status ?? "";
    var badge = status.Equals("Approved", StringComparison.OrdinalIgnoreCase) ? "bg-label-success"
              : status.Equals("Rejected", StringComparison.OrdinalIgnoreCase) ? "bg-label-danger"
              : "bg-label-warning";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Leave Details</h4>
    <a asp-action="Index" class="btn btn-label-secondary">
        <i class="icon-base ti tabler-arrow-left me-1"></i> Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Request Information</h5>
                <span class="badge rounded-pill @badge">@(string.IsNullOrEmpty(status) ? "Pending" : status)</span>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-body-secondary fw-normal">Employee</dt>
                    <dd class="col-sm-8 fw-medium">@Model.EmployeeName</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Leave Type</dt>
                    <dd class="col-sm-8 fw-medium">@Model.LeaveName</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Start Date</dt>
                    <dd class="col-sm-8 fw-medium">@Model.StartDate.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">End Date</dt>
                    <dd class="col-sm-8 fw-medium">@Model.EndDate?.ToString("dd MMM yyyy")@(Model.IsHalfDay ? " (half day)" : "")</dd>

                    <dt class="col-sm-4 text-body-secondary fw-normal">Note</dt>
                    <dd class="col-sm-8 fw-medium">@(string.IsNullOrEmpty(Model.Note) ? "—" : Model.Note)</dd>

                    @if (Model.DecidedAt.HasValue || !string.IsNullOrEmpty(Model.DecisionNote))
                    {
                        <dt class="col-sm-4 text-body-secondary fw-normal">Decision</dt>
                        <dd class="col-sm-8 fw-medium">
                            @(string.IsNullOrEmpty(status) ? "Pending" : status)
                            @if (Model.DecidedAt.HasValue)
                            {
                                <span class="text-body-secondary">on @Model.DecidedAt.Value.ToString("dd MMM yyyy HH:mm")</span>
                            }
                        </dd>

                        @if (!string.IsNullOrEmpty(Model.DecisionNote))
                        {
                            <dt class="col-sm-4 text-body-secondary fw-normal">Decision Note</dt>
                            <dd class="col-sm-8 fw-medium">@Model.DecisionNote</dd>
                        }
                    }
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-end gap-2">
                <a asp-action="Edit" asp-route-leaveId="@Model.Id" class="btn btn-primary">
                    <i class="icon-base ti tabler-edit me-1"></i> Edit
                </a>
                <form asp-action="Delete" asp-route-leaveId="@Model.Id" method="post" class="m-0"
                      onsubmit="return confirm('Are you sure you want to delete this leave?');">
                    <button type="submit" class="btn btn-label-danger">
                        <i class="icon-base ti tabler-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
