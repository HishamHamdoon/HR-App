@model List<Emp.Web.Dtos.ViewLeaveDto>
@using System
@{
    ViewData["Title"] = "Employee Leaves";
    Layout = "_AdminLayout";
}

<h2 class="mb-4 text-primary"><i class="fa fa-calendar-alt"></i> Employee Leaves</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (Model != null && Model.Any())
{
    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Employee</th>
                    <th>Leave Type</th>
                    <th>Days</th>
                    <th>Status</th>
                    <th>Reason</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var leave = Model[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@leave.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>@leave.EndDate?.ToString("yyyy-MM-dd")</td>
                        <td>@leave.EmployeeName</td>
                        <td>@leave.LeaveName</td>
                        <td>
                            @if (leave.Status != "APPROVED")
                            {
                                <span class="badge bg-warning">Pending</span>
                            }
                            else if (leave.Status == "APPROVED")
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Rejected</span>
                            }
                        </td>
                        <td>@leave.Note</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info text-center p-4 rounded-3 shadow-sm">
        <i class="fa fa-info-circle fa-lg"></i> You don't have leaves
    </div>
}
