@model Emp.Web.Dtos.UpdateLeaveDto
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Edit Leave";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <h4 class="mb-0">Edit Leave</h4>
    <a asp-action="Index" class="btn btn-label-secondary">
        <i class="icon-base ti tabler-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <div class="row g-5">
                        <div class="col-12">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Pending">Pending</option>
                                <option value="Approved">Approved</option>
                                <option value="Rejected">Rejected</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Note" class="form-label">Note</label>
                            <textarea asp-for="Note" class="form-control" rows="3" placeholder="Add a note for this decision..."></textarea>
                        </div>
                        <div class="col-12 d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-label-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success"><i class="icon-base ti tabler-device-floppy me-1"></i> Save Changes</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
