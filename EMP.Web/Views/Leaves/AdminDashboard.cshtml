@using EMP.Web.Models.Dtos
@model List<LeaveByManagerDto>
@{
    ViewData["Title"] = "Leaves By Manager";
    Layout = "_VuexyLayout";
}

<div class="mb-6">
    <h4 class="mb-0">Leaves for Manager</h4>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        @if (Model != null && Model.Any())
        {
            <table class="table table-hover border-top" data-paginate="10">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th>Note</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leave in Model)
                    {
                        var status = leave.Status ?? "";
                        var badge = status.Equals("Approved", StringComparison.OrdinalIgnoreCase) ? "bg-label-success"
                                  : status.Equals("Rejected", StringComparison.OrdinalIgnoreCase) ? "bg-label-danger"
                                  : "bg-label-warning";
                        <tr>
                            <td>@leave.Id</td>
                            <td class="fw-medium">@leave.EmployeeName</td>
                            <td>@leave.LeaveType</td>
                            <td>@leave.StartDate</td>
                            <td>@leave.EndDate</td>
                            <td><span class="badge rounded-pill @badge">@(string.IsNullOrEmpty(status) ? "Pending" : status)</span></td>
                            <td>@leave.Note</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a class="btn btn-icon btn-text-secondary rounded-pill" asp-controller="Leaves" asp-action="Details" asp-route-leaveId="@leave.Id" title="Details">
                                        <i class="icon-base ti tabler-eye"></i>
                                    </a>
                                    <a class="btn btn-icon btn-text-secondary rounded-pill" asp-controller="Leaves" asp-action="Edit" asp-route-leaveId="@leave.Id" title="Edit">
                                        <i class="icon-base ti tabler-edit"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-leaveId="@leave.Id" method="post" class="m-0"
                                          onsubmit="return confirm('Delete this record?')">
                                        <button type="submit" class="btn btn-icon btn-text-secondary rounded-pill" title="Delete">
                                            <i class="icon-base ti tabler-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center p-6">
                <i class="icon-base ti tabler-calendar-off mb-2" style="font-size:2.5rem;opacity:.4;"></i>
                <h6 class="mb-0">No leaves found for this manager</h6>
            </div>
        }
    </div>
</div>
