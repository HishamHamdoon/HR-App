@using Emp.Web.Dtos
@model PagedLeavesVM
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = "Leaves";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-6">
    <div>
        <h4 class="mb-1">Leaves Management</h4>
        <p class="mb-0 text-body-secondary">Review and manage employee leave requests</p>
    </div>
    <a asp-action="Create" asp-controller="Leaves" class="btn btn-primary">
        <i class="icon-base ti tabler-plus me-1"></i> Create New Leave
    </a>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        @if (Model.Leaves.Any())
        {
            <table class="table table-hover border-top">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Employee</th>
                        <th>Leave</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Manager</th>
                        <th>Days</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Leaves)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="fw-medium">@item.EmployeeName</td>
                            <td>@item.LeaveName</td>
                            <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@item.EndDate?.ToString("dd MMM yyyy")</td>
                            <td>@(string.IsNullOrEmpty(item.ManagerName) ? "—" : item.ManagerName)</td>
                            <td>
                                @if (item.EndDate.HasValue)
                                {
                                    @((item.EndDate.Value - item.StartDate).Days + 1)
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </td>
                            <td>
                                @{
                                    var status = item.Status ?? "";
                                    var badge = status.Equals("Approved", StringComparison.OrdinalIgnoreCase) ? "bg-label-success"
                                              : status.Equals("Rejected", StringComparison.OrdinalIgnoreCase) ? "bg-label-danger"
                                              : "bg-label-warning";
                                }
                                <span class="badge rounded-pill @badge">@(string.IsNullOrEmpty(status) ? "Pending" : status)</span>
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a class="btn btn-icon btn-text-secondary rounded-pill" asp-controller="Leaves" asp-action="Details" asp-route-leaveId="@item.Id" title="Details">
                                        <i class="icon-base ti tabler-eye"></i>
                                    </a>
                                    <a class="btn btn-icon btn-text-secondary rounded-pill" asp-controller="Leaves" asp-action="Edit" asp-route-leaveId="@item.Id" title="Edit">
                                        <i class="icon-base ti tabler-edit"></i>
                                    </a>
                                    @if (!string.IsNullOrEmpty(item.FilePath))
                                    {
                                        <a href="@item.FilePath" target="_blank" class="btn btn-icon btn-text-secondary rounded-pill" title="Attachment">
                                            <i class="icon-base ti tabler-paperclip"></i>
                                        </a>
                                    }
                                    <form asp-action="Delete" asp-route-leaveId="@item.Id" method="post" class="m-0"
                                          onsubmit="return confirm('Are you sure you want to delete this record?')">
                                        <button type="submit" class="btn btn-icon btn-text-secondary rounded-pill" title="Delete">
                                            <i class="icon-base ti tabler-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center p-6">
                <i class="icon-base ti tabler-calendar-off mb-2" style="font-size:2.5rem;opacity:.4;"></i>
                <h6 class="mb-0">No leaves found</h6>
            </div>
        }
    </div>

    @if (Model.Leaves.Any())
    {
        <div class="card-footer d-flex align-items-center justify-content-between flex-wrap gap-2">
            <span class="text-body-secondary">Showing @Model.Leaves.Count of @Model.TotalCount leaves</span>
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"><i class="icon-base ti tabler-chevron-left"></i></a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"><i class="icon-base ti tabler-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
