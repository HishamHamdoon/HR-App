@using Emp.Web.Dtos
@model PagedLeavesVM
@{
    Layout = "_VuexyLayout";
    ViewData["Title"] = L["Leaves"].Value;
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-6">
    <div>
        <h4 class="mb-1">@L["Leaves"]</h4>
        <p class="mb-0 text-body-secondary">@L["LeavesSubtitle"]</p>
    </div>
    <a asp-action="Create" asp-controller="Leaves" class="btn btn-primary">
        <i class="icon-base ti tabler-plus me-1"></i> @L["CreateNewLeave"]
    </a>
</div>

<div class="card">
    <div class="card-datatable table-responsive">
        @if (Model.Leaves.Any())
        {
            <table class="table table-hover border-top" data-paginate="10" data-search>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@L["Employee"]</th>
                        <th>@L["LeaveType"]</th>
                        <th>@L["StartDate"]</th>
                        <th>@L["EndDate"]</th>
                        <th>@L["Manager"]</th>
                        <th>@L["Days"]</th>
                        <th>@L["Status"]</th>
                        <th class="text-end">@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Leaves)
                    {
                        <tr data-href="@Url.Action("Details", new { leaveId = item.Id })">
                            <td>@item.Id</td>
                            <td class="fw-medium">@item.EmployeeName</td>
                            <td>@item.LeaveName</td>
                            <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@item.EndDate?.ToString("dd MMM yyyy")</td>
                            <td>@(string.IsNullOrEmpty(item.ManagerName) ? "—" : item.ManagerName)</td>
                            <td>
                                @if (item.EndDate.HasValue)
                                {
                                    @((item.EndDate.Value - item.StartDate).Days + 1)
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </td>
                            <td>
                                @{
                                    var status = item.Status ?? "";
                                    var badge = status.Equals("Approved", StringComparison.OrdinalIgnoreCase) ? "bg-label-success"
                                              : status.Equals("Rejected", StringComparison.OrdinalIgnoreCase) ? "bg-label-danger"
                                              : "bg-label-warning";
                                }
                                <span class="badge rounded-pill @badge">@(string.IsNullOrEmpty(status) ? "Pending" : status)</span>
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a class="btn btn-icon btn-text-secondary rounded-pill" asp-controller="Leaves" asp-action="Details" asp-route-leaveId="@item.Id" title="@L["Details"]">
                                        <i class="icon-base ti tabler-eye"></i>
                                    </a>
                                    <a class="btn btn-icon btn-text-secondary rounded-pill" asp-controller="Leaves" asp-action="Edit" asp-route-leaveId="@item.Id" title="@L["Edit"]">
                                        <i class="icon-base ti tabler-edit"></i>
                                    </a>
                                    @if (status.Equals("Pending", StringComparison.OrdinalIgnoreCase) || string.IsNullOrEmpty(status))
                                    {
                                        <form asp-controller="Leaves" asp-action="Approve" method="post" class="m-0">
                                            <input type="hidden" name="leaveId" value="@item.Id" />
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                            <button type="submit" class="btn btn-icon btn-text-secondary rounded-pill text-success" title="@L["Approve"]">
                                                <i class="icon-base ti tabler-check"></i>
                                            </button>
                                        </form>
                                        <form asp-controller="Leaves" asp-action="Reject" method="post" class="m-0"
                                              onsubmit="var n=prompt('Reason for rejection:'); if(n===null||n.trim()===''){return false;} this.note.value=n; return true;">
                                            <input type="hidden" name="leaveId" value="@item.Id" />
                                            <input type="hidden" name="note" />
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                            <button type="submit" class="btn btn-icon btn-text-secondary rounded-pill text-danger" title="@L["Reject"]">
                                                <i class="icon-base ti tabler-x"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (!string.IsNullOrEmpty(item.FilePath))
                                    {
                                        <a href="@item.FilePath" target="_blank" class="btn btn-icon btn-text-secondary rounded-pill" title="Attachment">
                                            <i class="icon-base ti tabler-paperclip"></i>
                                        </a>
                                    }
                                    <form asp-action="Delete" asp-route-leaveId="@item.Id" method="post" class="m-0"
                                          onsubmit="return confirm('Are you sure you want to delete this record?')">
                                        <button type="submit" class="btn btn-icon btn-text-secondary rounded-pill" title="@L["Delete"]">
                                            <i class="icon-base ti tabler-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center p-6">
                <i class="icon-base ti tabler-calendar-off mb-2" style="font-size:2.5rem;opacity:.4;"></i>
                <h6 class="mb-0">@L["NoRecords"]</h6>
            </div>
        }
    </div>

</div>
