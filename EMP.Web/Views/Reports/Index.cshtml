@{
    ViewData["Title"] = "Reports";
    Layout = "_AdminLayout";

}

<div class="container mt-4">
    <h2 class="mb-3">📊 HR Reports</h2>
    <p class="text-muted">Download and analyze reports for employees, departments, leaves, and payroll.</p>

    <div class="row">
        <!-- Employees -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body">
                    <h5 class="card-title">👤 Employee Reports</h5>
                    <p class="card-text text-muted">Employee details, headcount, positions, and join dates.</p>
                    <a asp-controller="Reports" asp-action="EmployeeReport" class="btn btn-sm btn-primary me-2">
                        PDF
                    </a>
                    <a asp-controller="Reports" asp-action="EmployeeExcelReport" class="btn btn-sm btn-success">
                        Excel
                    </a>
                </div>
            </div>
        </div>

        <!-- Departments -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body">
                    <h5 class="card-title">🏢 Department Reports</h5>
                    <p class="card-text text-muted">Department size, managers, and employee distribution.</p>
                    <a asp-controller="Reports" asp-action="DepartmentReport" class="btn btn-sm btn-primary me-2">
                        PDF
                    </a>
                    <a asp-controller="Reports" asp-action="DepartmentExcelReport" class="btn btn-sm btn-success">
                        Excel
                    </a>
                </div>
            </div>
        </div>

        <!-- Leaves -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body">
                    <h5 class="card-title">📅 Leave Reports</h5>
                    <p class="card-text text-muted">Leave balances, usage trends, and absence statistics.</p>
                    <a asp-controller="Reports" asp-action="LeaveReport" class="btn btn-sm btn-primary me-2">
                        PDF
                    </a>
                    <a asp-controller="Reports" asp-action="LeaveExcelReport" class="btn btn-sm btn-success">
                        Excel
                    </a>
                </div>
            </div>
        </div>

        <!-- Payroll -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body">
                    <h5 class="card-title">💰 Payroll Reports</h5>
                    <p class="card-text text-muted">Salary distribution, raises, and department cost breakdown.</p>
                    <a asp-controller="Reports" asp-action="PayrollReport" class="btn btn-sm btn-primary me-2">
                        PDF
                    </a>
                    <a asp-controller="Reports" asp-action="PayrollExcelReport" class="btn btn-sm btn-success">
                        Excel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
