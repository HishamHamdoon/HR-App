@{
    ViewData["Title"] = "HR Reports";
    Layout = "_VuexyLayout";
}

<div class="mb-6">
    <h4 class="mb-1">HR Reports</h4>
    <p class="mb-0 text-body-secondary">Download and analyze reports for employees, departments, leaves, and payroll.</p>
</div>

<div class="row g-6">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="avatar me-3">
                        <span class="avatar-initial rounded bg-label-primary"><i class="icon-base ti tabler-users icon-lg"></i></span>
                    </div>
                    <h5 class="mb-0">Employee Reports</h5>
                </div>
                <p class="text-body-secondary">Employee details, headcount, positions, and join dates.</p>
                <div class="d-flex gap-2">
                    <a asp-controller="Reports" asp-action="EmployeeReport" class="btn btn-sm btn-primary"><i class="icon-base ti tabler-file-type-pdf me-1"></i> PDF</a>
                    <a asp-controller="Reports" asp-action="EmployeeExcelReport" class="btn btn-sm btn-label-success"><i class="icon-base ti tabler-file-spreadsheet me-1"></i> Excel</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="avatar me-3">
                        <span class="avatar-initial rounded bg-label-warning"><i class="icon-base ti tabler-building icon-lg"></i></span>
                    </div>
                    <h5 class="mb-0">Department Reports</h5>
                </div>
                <p class="text-body-secondary">Department size, managers, and employee distribution.</p>
                <div class="d-flex gap-2">
                    <a asp-controller="Reports" asp-action="DepartmentReport" class="btn btn-sm btn-primary"><i class="icon-base ti tabler-file-type-pdf me-1"></i> PDF</a>
                    <a asp-controller="Reports" asp-action="DepartmentExcelReport" class="btn btn-sm btn-label-success"><i class="icon-base ti tabler-file-spreadsheet me-1"></i> Excel</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="avatar me-3">
                        <span class="avatar-initial rounded bg-label-success"><i class="icon-base ti tabler-calendar icon-lg"></i></span>
                    </div>
                    <h5 class="mb-0">Leave Reports</h5>
                </div>
                <p class="text-body-secondary">Leave balances, usage trends, and absence statistics.</p>
                <div class="d-flex gap-2">
                    <a asp-controller="Reports" asp-action="LeaveReport" class="btn btn-sm btn-primary"><i class="icon-base ti tabler-file-type-pdf me-1"></i> PDF</a>
                    <a asp-controller="Reports" asp-action="LeaveExcelReport" class="btn btn-sm btn-label-success"><i class="icon-base ti tabler-file-spreadsheet me-1"></i> Excel</a>
                </div>
            </div>
        </div>
    </div>

</div>
